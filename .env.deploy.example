POSTGRES_DB=fintech
POSTGRES_USER=fintech
POSTGRES_PASSWORD=replace-with-strong-password
AUTH_JWT_SECRET=replace-with-long-random-secret

# KIS mock/investment API (optional for preloaded DB-only mode, but needed for fallback)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_URL_BASE=https://openapivts.koreainvestment.com:29443
KIS_TR_ID=FHKST03010100

# Simulation time mode: REPLAY | LIVE
SIM_TIME_MODE=LIVE
SIM_TIME_TICK_SECONDS=60
SIM_TIME_STEP_DAYS=0
SIM_TIME_ZONE_ID=Asia/Seoul

# Async order queue
SIM_ORDER_ASYNC_ENABLED=false
SIM_ORDER_POLL_MILLIS=1000
SIM_ORDER_BATCH_SIZE=200
SIM_ORDER_MAX_RETRIES=3

# Real trading broker (SSAFY, etc.)
TRADING_BROKER_PROVIDER=SSAFY
TRADING_BROKER_MOCK_ENABLED=true
TRADING_BROKER_BASE_URL=
TRADING_BROKER_ACCOUNT_SNAPSHOT_PATH=/api/v1/accounts/{accountNo}/snapshot
TRADING_BROKER_ORDER_PATH=/api/v1/orders
TRADING_BROKER_APP_KEY=
TRADING_BROKER_APP_SECRET=
TRADING_BROKER_AUTH_HEADER_NAME=Authorization
TRADING_BROKER_TOKEN_PREFIX=Bearer 
TRADING_BROKER_APP_KEY_HEADER_NAME=X-APP-KEY
TRADING_BROKER_APP_SECRET_HEADER_NAME=X-APP-SECRET
