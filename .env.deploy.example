POSTGRES_DB=fintech
POSTGRES_USER=fintech
POSTGRES_PASSWORD=replace-with-strong-password
AUTH_JWT_SECRET=replace-with-long-random-secret

# KIS mock/investment API (optional for preloaded DB-only mode, but needed for fallback)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_URL_BASE=https://openapivts.koreainvestment.com:29443
KIS_TR_ID=FHKST03010100

# Simulation time mode: REPLAY | LIVE
SIM_TIME_MODE=REPLAY
SIM_TIME_TICK_SECONDS=60
SIM_TIME_STEP_DAYS=1
SIM_TIME_ZONE_ID=Asia/Seoul

# Async order queue
SIM_ORDER_ASYNC_ENABLED=false
SIM_ORDER_POLL_MILLIS=1000
SIM_ORDER_BATCH_SIZE=200
SIM_ORDER_MAX_RETRIES=3
